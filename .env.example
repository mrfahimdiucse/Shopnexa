# Shopnexa Environment Variables

# Gemini API Key (Injectable via UI)
GEMINI_API_KEY=""

# PostgreSQL Connection String
# Example: postgresql://user:password@localhost:5432/shopnexa?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/shopnexa?schema=public"

# JWT Secret
JWT_SECRET="your-super-secret-key-change-this-in-production"

# Port (Fixed at 3000 for this environment)
PORT=3000
